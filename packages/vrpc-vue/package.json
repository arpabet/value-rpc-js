{
  "name": "@arpabet/vrpc-vue",
  "version": "0.2.0",
  "description": "Vue 3 plugin and composables for value-rpc: useVrpcCall, useVrpcStream, useVrpcConnection",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@arpabet/vrpc": "^0.2.0"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "happy-dom": "^20.11.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10",
    "vue": "^3.5.0"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "vue",
    "composables",
    "rpc",
    "websocket",
    "value-rpc"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/arpabet/value-rpc-js.git",
    "directory": "packages/vrpc-vue"
  }
}
